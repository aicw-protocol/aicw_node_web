# Solana RPC (server + client)
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# TiDB Cloud (MySQL compatible) — use either DATABASE_URL or individual vars
# DATABASE_URL=mysql://user:password@host:4000/database?ssl=true
DATABASE_HOST=
DATABASE_PORT=4000
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
# Set to false for local MySQL without TLS
DATABASE_SSL=true

# Staking treasury wallet (server; also readable by API for client transfers)
STAKING_TREASURY_WALLET=

# Create Node flow (client-safe)
NEXT_PUBLIC_NODE_WEB_API_URL=http://localhost:4003
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_AICW_NODE_RELEASES_URL=https://github.com/aicw-protocol/aicw_node/releases
NEXT_PUBLIC_NODE_PING_INTERVAL_SECONDS=90

# Desktop GUI wallet sign-in (server secret for challenge tokens)
GUI_AUTH_SECRET=

# Consul — auto-add nodes to MPC membership whitelist on Dashboard registration
# Set CONSUL_AUTO_WHITELIST=false to disable (DB-only registration)
CONSUL_HTTP_ADDR=158.247.251.191:8500
CONSUL_AUTO_WHITELIST=true
# CONSUL_HTTP_TOKEN=
# CONSUL_MEMBERSHIP_WHITELIST_PREFIX=mpc_eligibility/membership_whitelist/
# CONSUL_WHITELIST_ADDED_BY=aicw_node_web
